{
    "manifest_version": 3,
    "name": "Docs Markdown Cleaner",
    "description": "Converts copied web content to Markdown and inspects raw clipboard contents.",
    "version": "0.6.6",
    "version_name": "0.6.6",
    "permissions": [
        "activeTab",
        "scripting",
        "clipboardRead",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "icons": {
        "16": "icon128.png",
        "48": "icon128.png",
        "128": "icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "commands": {
        "run-markdown-clean": {
            "suggested_key": {
                "default": "Ctrl+Shift+U",
                "mac": "Command+Shift+U"
            },
            "description": "Clean Docs selection via Markdown"
        },
        "inspect-clipboard": {
            "suggested_key": {
                "default": "Ctrl+Shift+O",
                "mac": "Command+Shift+O"
            },
            "description": "Inspect the clipboard contents"
        }
    }
}